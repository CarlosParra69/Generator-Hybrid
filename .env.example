# LLM Provider Configuration
LLM_PROVIDER=groq

# Groq API Configuration (Free API - Recommended)
GROQ_API_KEY={YOUR_GROQ_API_KEY}

# En .env o como variable de entorno:
BATCH_COOLDOWN_SEC=15   # 15 segundos entre batches
BATCH_COOLDOWN_SEC=8    # sin cooldown (deshabilitado)

# Trainer API Configuration
TRAINER_API_URL=http://localhost:8000/train
TRAINER_API_TIMEOUT=30

# Generation Configuration
NUM_EXAMS_TO_GENERATE=1
INFINITE_MODE=false
BATCH_SIZE=5

# Error Injection Configuration
ERROR_INJECTION_PROBABILITY=0.4

# MCQ Configuration
MCQ_CORRECT_PROBABILITY=0.70

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=synthetic_training_generator.log

# Training Data
TRAINING_DATA_FILE=sample/train_french_priority.json
